# ==============================
# Service runtime
# ==============================
# Enables FastAPI debug mode.
MODE_DEBUG=False
# Python logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL.
LOG_LEVEL=INFO
# Values shown in OpenAPI and /health payload.
SERVICE_NAME=ArXiv Superconductor Papers Sync Service
SERVICE_VERSION=0.1.0

# ==============================
# Storage
# ==============================
# Root folder for saved PDF/TXT artifacts.
# In docker-compose this is typically mounted to /app/storage.
STORAGE_PATH=storage

# ==============================
# Scheduler (F002)
# ==============================
# Unique scheduler configuration key in DB.
SCHEDULER_JOB_NAME=sync_pipeline
# Default cron (UTC) used when scheduler config is first created.
SCHEDULER_DEFAULT_CRON=0 * * * *

# ==============================
# Sync pipeline (F001)
# ==============================
# Safety overlap in days for incremental OAI sync.
SYNC_OVERLAP_DAYS=2
# Max number of papers processed per pipeline run.
SYNC_PROCESS_BATCH_SIZE=300

# OAI-PMH metadata source.
ARXIV_OAI_BASE_URL=https://oaipmh.arxiv.org/oai
# Upstream set spec; service filters cond-mat.supr-con records downstream.
ARXIV_OAI_SET=physics:cond-mat
# Optional XML manifest URL for TAR index lookup (empty to disable).
ARXIV_MANIFEST_URL=
# HTTP fallback PDF endpoint.
ARXIV_PDF_BASE_URL=https://arxiv.org/pdf
# Shared HTTP timeout for upstream calls (seconds).
ARXIV_HTTP_TIMEOUT_SECONDS=60

# Optional arXiv S3 TAR mode.
# If True and TAR key is known, service tries S3 before HTTP fallback.
ARXIV_PDF_USE_S3=False
ARXIV_S3_BUCKET=arxiv
ARXIV_S3_REGION=us-east-1
# arXiv public bucket normally requires requester-pays mode.
ARXIV_S3_REQUEST_PAYER=True

# ==============================
# Database
# ==============================
# DB_ENGINE examples: postgresql | sqlite | sqlite+aiosqlite.
DB_ENGINE=postgresql
# For docker-compose this is usually "postgres".
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sync_service
DB_USER=postgres
DB_PASSWORD=postgres
